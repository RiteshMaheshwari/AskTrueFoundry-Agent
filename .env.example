# TrueFoundry AI Gateway credentials.
# Never commit a real token. Rotate any token that was ever pasted into source.
TRUEFOUNDRY_API_KEY=

# OpenAI-compatible AI Gateway endpoint.
TFY_GATEWAY_BASE_URL=https://gateway.truefoundry.ai

# Gateway model IDs. MODEL is also supported as a fallback for generation.
TFY_GENERATION_MODEL=openai/gpt-5.4-nano
TFY_EMBEDDING_MODEL=openai/text-embedding-3-small
TFY_GENERATION_MAX_TOKENS=1200

# Local RAG index paths.
ASKTF_DATA_DIR=data
ASKTF_INDEX_PATH=data/index.jsonl
ASKTF_EMBEDDINGS_PATH=data/embeddings.npy

# Retrieval defaults.
ASKTF_TOP_K=4
ASKTF_MIN_SIMILARITY=0.15
ASKTF_MAX_CONTEXT_CHARS_PER_SOURCE=1800
